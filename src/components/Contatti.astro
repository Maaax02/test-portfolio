---
import { site } from '../data/site';

const waLink = site.whatsapp
  ? `https://wa.me/${site.whatsapp}?text=${encodeURIComponent('Ciao! Vorrei un audit gratuito del mio sito.')}`
  : null;
---

<section class="section is-dark" id="contatti">
  <div class="wrap contatti">
    <div class="contatti-intro" data-reveal>
      <p class="eyebrow">Audit gratuito</p>
      <h2>Scopriamo cosa frena il tuo sito. Gratis.</h2>
      <p class="contatti-lede">
        Mandami il link del tuo sito (o dimmi che non ne hai ancora uno). Ti rispondo
        con un’analisi concreta: cosa funziona, cosa ti sta facendo perdere clienti e
        da dove conviene partire. Nessun impegno.
      </p>

      <ul class="direct">
        <li>
          <span class="direct-label mono">Email</span>
          <a href={`mailto:${site.email}`}>{site.email}</a>
        </li>
        {site.telefonoVisibile && (
          <li>
            <span class="direct-label mono">Telefono</span>
            <span>{site.telefonoVisibile}</span>
          </li>
        )}
        {waLink && (
          <li>
            <span class="direct-label mono">WhatsApp</span>
            <a href={waLink} target="_blank" rel="noopener">Scrivimi su WhatsApp</a>
          </li>
        )}
      </ul>
    </div>

    <form
      class="form"
      id="audit-form"
      action={site.formspreeEndpoint}
      method="POST"
      novalidate
      data-reveal
    >
      <div class="field">
        <label for="nome">Nome</label>
        <input id="nome" name="nome" type="text" autocomplete="name" required placeholder="Come ti chiami" />
        <p class="err" data-err-for="nome" hidden>Dimmi come ti chiami.</p>
      </div>

      <div class="field">
        <label for="email">Email</label>
        <input id="email" name="email" type="email" autocomplete="email" required placeholder="dove ti rispondo" />
        <p class="err" data-err-for="email" hidden>Inserisci una email valida, così posso risponderti.</p>
      </div>

      <div class="field">
        <label for="sito">Il tuo sito <span class="opt">(facoltativo)</span></label>
        <input id="sito" name="sito" type="url" inputmode="url" placeholder="https://… oppure lascia vuoto" />
      </div>

      <div class="field">
        <label for="messaggio">Di cosa hai bisogno?</label>
        <textarea id="messaggio" name="messaggio" rows="4" required placeholder="Due righe sulla tua attività e su cosa vorresti ottenere"></textarea>
        <p class="err" data-err-for="messaggio" hidden>Scrivimi due righe: anche poche bastano.</p>
      </div>

      <!-- onestà: per chi arriva via Formspree, oggetto leggibile -->
      <input type="hidden" name="_subject" value="Richiesta audit gratuito dal sito" />

      <button class="btn form-submit" type="submit">
        Invia la richiesta <span class="arrow" aria-hidden="true">→</span>
      </button>

      <p class="form-status" id="form-status" role="status" aria-live="polite" hidden></p>
      <p class="form-note mono">Niente spam. I tuoi dati servono solo per risponderti.</p>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById('audit-form') as HTMLFormElement | null;
  if (form) {
    const status = document.getElementById('form-status') as HTMLElement;

    const showError = (name: string, show: boolean) => {
      const field = form.querySelector(`[name="${name}"]`) as HTMLElement | null;
      const err = form.querySelector(`[data-err-for="${name}"]`) as HTMLElement | null;
      if (err) err.hidden = !show;
      if (field) field.setAttribute('aria-invalid', show ? 'true' : 'false');
    };

    const validate = () => {
      let ok = true;
      const nome = (form.elements.namedItem('nome') as HTMLInputElement).value.trim();
      const email = (form.elements.namedItem('email') as HTMLInputElement).value.trim();
      const messaggio = (form.elements.namedItem('messaggio') as HTMLTextAreaElement).value.trim();

      const emailOk = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
      showError('nome', nome === '');
      showError('email', !emailOk);
      showError('messaggio', messaggio === '');
      if (nome === '' || !emailOk || messaggio === '') ok = false;
      return ok;
    };

    // pulisce l'errore mentre l'utente corregge
    form.querySelectorAll('input, textarea').forEach((el) => {
      el.addEventListener('input', () => showError((el as HTMLInputElement).name, false));
    });

    const setStatus = (msg: string, kind: 'ok' | 'ko') => {
      status.hidden = false;
      status.textContent = msg;
      status.dataset.kind = kind;
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!validate()) {
        setStatus('Controlla i campi evidenziati e riprova.', 'ko');
        const firstErr = form.querySelector('[aria-invalid="true"]') as HTMLElement | null;
        firstErr?.focus();
        return;
      }

      const endpoint = form.getAttribute('action') || '';
      // se l'endpoint non è ancora configurato, evita un invio inutile
      if (endpoint.includes('your-id')) {
        setStatus('Form in fase di configurazione. Scrivimi pure via email qui sopra.', 'ko');
        return;
      }

      const submitBtn = form.querySelector('.form-submit') as HTMLButtonElement;
      submitBtn.disabled = true;
      setStatus('Invio in corso…', 'ok');

      try {
        const res = await fetch(endpoint, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });
        if (res.ok) {
          form.reset();
          setStatus('Ricevuto. Ti rispondo entro un giorno lavorativo.', 'ok');
        } else {
          setStatus('Qualcosa è andato storto. Riprova o scrivimi via email.', 'ko');
        }
      } catch {
        setStatus('Connessione assente. Riprova o scrivimi via email.', 'ko');
      } finally {
        submitBtn.disabled = false;
      }
    });
  }
</script>

<style>
  .contatti {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  @media (min-width: 900px) {
    .contatti {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-2xl);
      align-items: start;
    }
  }

  .contatti-intro .eyebrow {
    color: var(--ocra);
    margin-bottom: var(--space-s);
  }

  .contatti-lede {
    margin-top: var(--space-m);
    color: var(--fg-muted);
    font-size: var(--step-1);
    max-width: 50ch;
  }

  .direct {
    list-style: none;
    padding: 0;
    margin-top: var(--space-l);
    display: grid;
    gap: var(--space-s);
  }

  .direct li {
    display: flex;
    align-items: baseline;
    gap: var(--space-s);
    border-top: 1px solid var(--linea);
    padding-top: var(--space-s);
  }

  .direct-label {
    flex: 0 0 6.5rem;
    font-size: var(--step--1);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-muted);
  }

  .direct a {
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s var(--ease);
  }

  .direct a:hover {
    border-color: var(--ocra);
  }

  /* ---- Form ---- */
  .form {
    background: color-mix(in srgb, var(--gesso) 8%, transparent);
    border: 1px solid var(--linea);
    border-radius: var(--radius-l);
    padding: clamp(1.4rem, 4vw, 2.4rem);
    display: grid;
    gap: var(--space-m);
  }

  .field {
    display: grid;
    gap: 0.45rem;
  }

  label {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.04em;
  }

  .opt {
    color: var(--fg-muted);
    text-transform: none;
    letter-spacing: 0;
  }

  input,
  textarea {
    font: inherit;
    color: var(--gesso);
    background: rgba(16, 36, 86, 0.35);
    border: 1px solid var(--linea);
    border-radius: var(--radius-s);
    padding: 0.8rem 0.95rem;
    transition: border-color 0.2s var(--ease), box-shadow 0.2s var(--ease);
  }

  input::placeholder,
  textarea::placeholder {
    color: rgba(242, 238, 230, 0.45);
  }

  input:focus,
  textarea:focus {
    outline: none;
    border-color: var(--ocra);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--ocra) 30%, transparent);
  }

  input[aria-invalid='true'],
  textarea[aria-invalid='true'] {
    border-color: #ff9b8a;
  }

  textarea {
    resize: vertical;
    min-height: 6rem;
  }

  .err {
    color: #ffb4a6;
    font-size: var(--step--1);
  }

  .form-submit {
    justify-self: start;
    margin-top: var(--space-2xs);
  }

  .form-submit:disabled {
    opacity: 0.6;
    cursor: progress;
  }

  .form-status {
    font-size: var(--step-0);
    padding: 0.7rem 0.9rem;
    border-radius: var(--radius-s);
  }

  .form-status[data-kind='ok'] {
    background: color-mix(in srgb, var(--verde-maiolica) 30%, transparent);
    color: var(--gesso);
  }

  .form-status[data-kind='ko'] {
    background: rgba(255, 120, 100, 0.18);
    color: #ffd4cc;
  }

  .form-note {
    font-size: 0.74rem;
    color: var(--fg-muted);
  }
</style>
