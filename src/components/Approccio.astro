---
const fasi = [
  {
    n: '01',
    titolo: 'Ci parliamo',
    testo:
      'Una chiamata per capire la tua attività, i tuoi clienti e cosa ti serve davvero. Niente gergo, solo domande utili.',
  },
  {
    n: '02',
    titolo: 'Ti mostro una direzione',
    testo:
      'Prima di partire ti faccio vedere dove voglio andare: design, struttura, contenuti. Decidiamo insieme, senza sorprese.',
  },
  {
    n: '03',
    titolo: 'Costruisco e ti aggiorno',
    testo:
      'Lavoro a tappe e ti tengo aggiornato con tempi chiari. Tu vedi i progressi, io resto reperibile.',
  },
  {
    n: '04',
    titolo: 'Andiamo online (e resto)',
    testo:
      'Pubblichiamo il sito e ti spiego come gestirlo. Per le piccole modifiche non devi dipendere da nessuno.',
  },
];
---

<section class="section" id="approccio">
  <div class="wrap approccio">
    <header class="sec-head" data-reveal>
      <p class="eyebrow">Come lavoro</p>
      <h2>Un metodo chiaro, dalla prima chiamata al sito online.</h2>
      <p class="sec-sub">
        Lavorare con un freelance non deve far paura. Comunicazione diretta, tempi
        concordati e nessun tecnicismo che non ti serve.
      </p>
    </header>

    <ol class="steps">
      {
        fasi.map((f, i) => (
          <li class="step" data-reveal style={`--reveal-delay:${i * 80}ms`}>
            <span class="step-n mono">{f.n}</span>
            <div>
              <h3>{f.titolo}</h3>
              <p>{f.testo}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .approccio {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  @media (min-width: 900px) {
    .approccio {
      grid-template-columns: 0.85fr 1.15fr;
      gap: var(--space-2xl);
      align-items: start;
    }
  }

  .sec-head {
    max-width: 40ch;
  }

  .sec-head .eyebrow {
    margin-bottom: var(--space-s);
  }

  .sec-sub {
    margin-top: var(--space-m);
    color: var(--fg-muted);
    font-size: var(--step-1);
  }

  .steps {
    list-style: none;
    margin: 0;
    padding: 0;
    counter-reset: step;
  }

  .step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-m);
    padding-block: var(--space-m);
    border-top: 1px solid var(--linea);
  }

  .step:last-child {
    border-bottom: 1px solid var(--linea);
  }

  .step-n {
    font-size: var(--step-2);
    font-weight: 700;
    color: var(--ocra-prof);
    line-height: 1;
  }

  .step h3 {
    font-size: var(--step-1);
    margin-bottom: 0.35rem;
  }

  .step p {
    color: var(--fg-muted);
    max-width: 52ch;
  }
</style>
