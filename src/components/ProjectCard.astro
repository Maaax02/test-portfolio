---
import type { CollectionEntry } from 'astro:content';
import { link } from '../lib/url';

interface Props {
  project: CollectionEntry<'projects'>;
  index: number;
}

const { project, index } = Astro.props;
const { data, slug } = project;
---

<a class={`pcard tint-${data.tinta}`} href={link(`lavori/${slug}`)} data-reveal style={`--reveal-delay:${index * 90}ms`}>
  <div class="pcard-top">
    {data.concept && <span class="badge mono">Progetto dimostrativo</span>}
    <span class="pcard-sector mono">{data.settore}</span>
  </div>

  <!-- "campione di smalto" generativo al posto di una foto finta -->
  <div class="swatch" aria-hidden="true">
    <span class="swatch-glaze"></span>
    <span class="swatch-ring"></span>
  </div>

  <h3 class="pcard-title">{data.titolo}</h3>
  <p class="pcard-sintesi">{data.sintesi}</p>

  <ul class="pcard-tech" aria-label="Tecnologie">
    {data.tecnologie.slice(0, 3).map((t) => <li class="mono">{t}</li>)}
  </ul>

  <span class="pcard-cta mono">
    Apri il caso <span class="arrow" aria-hidden="true">→</span>
  </span>
</a>

<style>
  .pcard {
    --tint: var(--cobalto);
    display: flex;
    flex-direction: column;
    background: var(--bg-elev);
    border: 1px solid var(--linea);
    border-radius: var(--radius-l);
    padding: var(--space-m);
    overflow: hidden;
    transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease),
      border-color 0.3s var(--ease);
  }

  .tint-cobalto {
    --tint: var(--cobalto);
  }
  .tint-verde {
    --tint: var(--verde-maiolica);
  }
  .tint-ocra {
    --tint: var(--ocra-prof);
  }

  .pcard:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-soft);
    border-color: color-mix(in srgb, var(--tint) 45%, var(--linea));
  }

  .pcard-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-s);
    font-size: var(--step--1);
    flex-wrap: wrap;
  }

  .badge {
    display: inline-block;
    padding: 0.25rem 0.6rem;
    border-radius: var(--radius-pill);
    background: color-mix(in srgb, var(--tint) 14%, transparent);
    color: var(--tint);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;
  }

  .pcard-sector {
    color: var(--fg-muted);
    letter-spacing: 0.04em;
  }

  /* ---- campione di smalto ---- */
  .swatch {
    position: relative;
    aspect-ratio: 16 / 9;
    margin-block: var(--space-m);
    border-radius: var(--radius-m);
    background: linear-gradient(135deg, var(--tint), var(--cobalto-prof));
    overflow: hidden;
    isolation: isolate;
  }

  .swatch-glaze {
    position: absolute;
    inset: -30%;
    background: radial-gradient(
      40% 40% at 30% 25%,
      rgba(255, 255, 255, 0.55),
      transparent 60%
    );
    mix-blend-mode: screen;
    transition: transform 0.6s var(--ease);
  }

  .swatch-ring {
    position: absolute;
    right: -14%;
    bottom: -28%;
    width: 62%;
    aspect-ratio: 1;
    border-radius: 50%;
    border: 1.5px solid rgba(242, 238, 230, 0.4);
    box-shadow: inset 0 0 0 14px rgba(242, 238, 230, 0.08);
  }

  .pcard:hover .swatch-glaze {
    transform: translate(8%, 6%);
  }

  .pcard-title {
    font-size: var(--step-1);
    line-height: 1.12;
  }

  .pcard-sintesi {
    margin-top: var(--space-2xs);
    color: var(--fg-muted);
    font-size: var(--step-0);
  }

  .pcard-tech {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: var(--space-m);
  }

  .pcard-tech li {
    font-size: 0.74rem;
    padding: 0.22rem 0.6rem;
    border: 1px solid var(--linea);
    border-radius: var(--radius-pill);
    color: var(--fg-muted);
  }

  .pcard-cta {
    margin-top: var(--space-m);
    padding-top: var(--space-s);
    border-top: 1px solid var(--linea);
    color: var(--tint);
    font-weight: 700;
    font-size: var(--step--1);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .pcard:hover .arrow {
    transform: translateX(4px);
  }

  .arrow {
    transition: transform 0.25s var(--ease);
  }

  @media (prefers-reduced-motion: reduce) {
    .pcard,
    .swatch-glaze,
    .arrow {
      transition: none;
    }
  }
</style>
